# A simple Python program to calculate grades

def calculate_grade(marks):
    if marks >= 90:
        return "A+"
    elif marks >= 80:
        return "A"
    elif marks >= 70:
        return "B"
    elif marks >= 60:
        return "C"
    elif marks >= 50:
        return "D"
    else:
        return "Fail"

if __name__ == "__main__":
    student_name = input("Enter student name: ")
    marks = int(input("Enter marks (0-100): "))
    
    grade = calculate_grade(marks)
    print(f"{student_name} scored {marks} and received grade {grade}.")
